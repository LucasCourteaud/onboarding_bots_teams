{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "{{TEAMS_APP_ID}}",
  "developer": {
    "name": "EPITECH",
    "websiteUrl": "https://www.epitech.eu/",
    "privacyUrl": "https://www.epitech.eu/politique-de-confidentialite/",
    "termsOfUseUrl": "https://www.epitech.eu/mentions-legales/"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "BotTeams",
    "full": "BotTeams Onboarding POC"
  },
  "description": {
    "short": "Bot Teams d'onboarding pour MyEPITECH.",
    "full": "Bot Microsoft Teams de proof of concept pour automatiser le parcours d'onboarding, les notifications Planner et le reporting EPITECH."
  },
  "accentColor": "#0A2A43",
  "bots": [
    {
      "botId": "{{BOT_APP_ID}}",
      "scopes": [
        "personal",
        "team"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team"
          ],
          "commands": [
            {
              "title": "help",
              "description": "Affiche les commandes disponibles."
            },
            {
              "title": "status",
              "description": "Retourne l'état du bot."
            },
            {
              "title": "ping",
              "description": "Test simple du canal Teams."
            }
          ]
        }
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "{{PUBLIC_HOSTNAME}}"
  ]
}